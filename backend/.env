# Server Config
PORT=5001
NODE_ENV=development

# Database
# Use local MongoDB for immediate usage, fallback to Atlas URI if provided
MONGODB_URI=mongodb://127.0.0.1:27017/flowwise_ai

# JWT Secrets
JWT_SECRET=super_secret_flowwise_access_token_key_2026_jwt_token
JWT_REFRESH_SECRET=super_secret_flowwise_refresh_token_key_2026_jwt_token
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary Config (Mock used if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI Config (Mock smart rules used if empty)
GEMINI_API_KEY=
